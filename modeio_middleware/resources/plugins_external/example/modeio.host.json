{
  "version": "1",
  "runtime": "stdio_jsonrpc",
  "command": [
    "python3",
    "./plugin.py"
  ],
  "defaults": {
    "mode": "observe",
    "capabilities_grant": {
      "can_patch": false,
      "can_block": false
    },
    "pool_size": 1,
    "timeout_ms": {
      "pre.request": 150,
      "post.response": 120
    }
  }
}
